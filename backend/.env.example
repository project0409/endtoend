# Backend Environment Variables Example
# Copy this to .env and fill in your actual values

# MongoDB Connection String
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/interview-prep?retryWrites=true&w=majority
# For Local MongoDB: mongodb://localhost:27017/interview-prep
MONGODB_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/interview-prep?retryWrites=true&w=majority

# JWT Secret Key (generate a strong random string for production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Server Port
PORT=5000

# Environment
NODE_ENV=development
